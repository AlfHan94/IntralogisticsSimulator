@model List<IntralogisticsSimulator.Models.Product>

@{
    ViewData["Title"] = "Produkter i lager";
}

<div class="container mt-4">
    <h1>📦 Produkter i lager</h1>
    <p class="text-muted">Detta är alla produkter som finns i vårt lagersystem just nu.</p>

    <table class="table table-striped table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Produktnamn</th>
                <th>Antal i lager</th>
                <th>Lagerplats</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td><strong>@product.Name</strong></td>
                    <td>
                        @if (product.QuantityInStock < 20)
                        {
                            <span class="badge bg-warning">⚠️ @product.QuantityInStock st</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@product.QuantityInStock st</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-secondary">📍 @product.Location</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="alert alert-info mt-4">
        <strong>💡 Info:</strong> Detta är testdata som lagras i minnet.
        När du startar om appen återställs datan.
    </div>
</div>