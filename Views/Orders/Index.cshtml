@model List<IntralogisticsSimulator.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-4">
    <h1>📋 Orders</h1>
    <p class="text-muted">Alla ordrar som ska plockas i lagret.</p>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <strong>ℹ️ Inga orders finns ännu.</strong>
            <p>När en order skapas kommer den att visas här.</p>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Order #@order.Id</h5>
                    <div>
                        @if (order.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">⏳ @order.Status</span>
                        }
                        else if (order.Status == "InProgress")
                        {
                            <span class="badge bg-info">🔄 @order.Status</span>
                        }
                        else if (order.Status == "Completed")
                        {
                            <span class="badge bg-success">✅ @order.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@order.Status</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <strong>Skapad:</strong> @order.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                    </p>

                    <h6>Orderrader:</h6>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Produkt</th>
                                <th>Lagerplats</th>
                                <th>Antal att plocka</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in order.OrderItems)
                            {
                                <tr>
                                    <td>
                                        @if (item.Product != null)
                                        {
                                            <strong>@item.Product.Name</strong>
                                            <br />
                                            <small class="text-muted">ID: @item.ProductId</small>
                                        }
                                        else
                                        {
                                            <span class="text-danger">⚠️ Produkt #@item.ProductId (hittades ej)</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Product != null)
                                        {
                                            <span class="badge bg-secondary">📍 @item.Product.Location</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td><strong>@item.Quantity st</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    <div class="alert alert-info mt-4">
        <strong>💡 Nästa steg:</strong> Vi kommer snart lägga till en knapp för att skapa nya orders!
    </div>
</div>
